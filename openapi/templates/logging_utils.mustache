import json
from urllib.parse import urlparse

_REDACTED_HEADERS = {"authorization", "x-api-key", "cookie", "set-cookie"}


def redact_headers(headers: dict) -> dict:
    redacted = {}
    for key, value in headers.items():
        if key.lower() in _REDACTED_HEADERS:
            redacted[key] = "***REDACTED***"
        else:
            redacted[key] = value
    return redacted


def format_payload(payload):
    if payload is None:
        return None
    if isinstance(payload, bytes):
        return payload.decode("utf-8", errors="replace")
    return str(payload)


def request_body_for_log(payload, headers: dict):
    value = format_payload(payload)
    if value is None:
        return None

    content_type = headers.get("Content-Type", "")
    if isinstance(value, str) and "json" in content_type.lower():
        try:
            return json.loads(value)
        except json.JSONDecodeError:
            return value
    return value


def response_body_for_log(payload):
    text = format_payload(payload)
    if text is None:
        return None

    if isinstance(text, str):
        try:
            return json.loads(text)
        except json.JSONDecodeError:
            return text
    return text


def build_summary(prefix: str, method: str, url: str, status_code: int | None = None) -> str:
    parsed_url = urlparse(url)
    base_url = f"{parsed_url.scheme}://{parsed_url.netloc}"
    path_and_query = parsed_url.path
    if parsed_url.query:
        path_and_query += f"?{parsed_url.query}"

    if status_code is None:
        return f"{prefix}: {base_url} {method.upper()} {path_and_query}"

    return (
        f"{prefix}: {base_url} {method.upper()} {path_and_query} "
        f"[{status_code}]"
    )


def pretty_log(summary: str, payload: dict) -> str:
    pretty_payload = json.dumps(payload, default=str, ensure_ascii=False, indent=2)
    indented_payload = "\n  " + pretty_payload.replace("\n", "\n  ")
    return f"{summary}{indented_payload}"
